# Copy this file to ".env" and paste the real values from:
#   Netlify -> Site settings -> Environment variables
# .env is gitignored and must never be committed.
#
# The same variables must be set in Netlify for the deployed site/functions.

# ── Supabase ──────────────────────────────────────────────────────────────
# Project URL is public. The functions also hard-code it as a fallback, but
# set it anyway for clarity.
SUPABASE_URL=https://yzndkdlzgegrcotfeqlp.supabase.co
# service_role key (SECRET) — server functions only. Supabase -> Project
# Settings -> API -> service_role. Never expose to the browser.
SUPABASE_SERVICE_KEY=
# anon/public key — used by functions to verify a user's auth token, and by
# the frontend (as VITE_SUPABASE_ANON_KEY at build time).
VITE_SUPABASE_ANON_KEY=
# Optional alias some functions also accept:
# SUPABASE_ANON_KEY=

# ── Microsoft / Outlook (Graph API) ───────────────────────────────────────
# Azure app registration. Required to send invoices via Outlook and file to OneDrive.
# (Overdue reminders do NOT use Outlook — they send via Resend; see RESEND_API_KEY.)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# The OAuth redirect URL registered in Azure, e.g.
# https://bkeeper.netlify.app/.netlify/functions/outlook-oauth-callback
MICROSOFT_REDIRECT_URI=

# ── Resend (overdue reminder emails) ──────────────────────────────────────
# Resend delivers the automatic overdue-invoice reminders (send-reminders.mjs),
# NOT Outlook. Get the key from resend.com -> API Keys. Without it, reminders
# can't send (dry-run preview still works).
RESEND_API_KEY=
# From address for reminder emails (default noreply@mworxgroup.com.au).
# Must be a verified sender/domain in Resend.
# REMINDER_FROM_EMAIL=noreply@mworxgroup.com.au
# BCC address copied on EVERY reminder (automatic + manual) so you get a record
# of exactly what was sent and to whom (default info@mworxgroup.com.au).
# Set to an empty value to turn BCC off.
# REMINDER_BCC_EMAIL=info@mworxgroup.com.au

# ── Stripe (card payments for invoices) ───────────────────────────────────
# Secret API key from dashboard.stripe.com -> Developers -> API keys.
# Use sk_test_... while testing, sk_live_... in production. Server-only — never
# expose to the browser. When set, invoices gain a "Pay by card" button/link.
STRIPE_SECRET_KEY=
# Signing secret for the webhook endpoint (Developers -> Webhooks -> your
# endpoint -> Signing secret). Starts with whsec_. Used by stripe-webhook.mjs to
# verify Stripe's signature. Webhook URL: https://bkeeper.netlify.app/.netlify/functions/stripe-webhook
# (event: checkout.session.completed).
STRIPE_WEBHOOK_SECRET=
# Card surcharge % passed on to the customer at checkout (default 1.7 ≈ Stripe's
# AU domestic card rate). Set to 0 to absorb the fee instead.
# STRIPE_SURCHARGE_PCT=1.7

# ── Token encryption ──────────────────────────────────────────────────────
# 32-byte key as 64 hex chars. Used to encrypt/decrypt stored Outlook tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: changing this invalidates all stored Outlook tokens (reconnect needed).
TOKEN_ENCRYPTION_KEY=

# ── Receipt scanning (Anthropic) ──────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────
# Business timezone for reminder date math (default Australia/Sydney).
# BUSINESS_TIMEZONE=Australia/Sydney
# Netlify sets URL automatically in production; only needed for local override.
# URL=https://bkeeper.netlify.app
