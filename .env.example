# Copy this file to ".env" and paste the real values from:
#   Netlify -> Site settings -> Environment variables
# .env is gitignored and must never be committed.

# --- Supabase (required for preview AND send) ---
SUPABASE_URL=https://yzndkdlzgegrcotfeqlp.supabase.co
SUPABASE_SERVICE_KEY=

# --- Microsoft / Outlook (required only for --send) ---
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Token encryption key (required only for --send) ---
# The same key the deployed functions use to decrypt the stored Outlook token.
TOKEN_ENCRYPTION_KEY=
