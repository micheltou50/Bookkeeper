# Copy this file to ".env" and paste the real values from:
#   Netlify -> Site settings -> Environment variables
# .env is gitignored and must never be committed.
#
# The same variables must be set in Netlify for the deployed site/functions.

# ── Supabase ──────────────────────────────────────────────────────────────
# Project URL is public. The functions also hard-code it as a fallback, but
# set it anyway for clarity.
SUPABASE_URL=https://yzndkdlzgegrcotfeqlp.supabase.co
# service_role key (SECRET) — server functions only. Supabase -> Project
# Settings -> API -> service_role. Never expose to the browser.
SUPABASE_SERVICE_KEY=
# anon/public key — used by functions to verify a user's auth token, and by
# the frontend (as VITE_SUPABASE_ANON_KEY at build time).
VITE_SUPABASE_ANON_KEY=
# Optional alias some functions also accept:
# SUPABASE_ANON_KEY=

# ── Microsoft / Outlook (Graph API) ───────────────────────────────────────
# Azure app registration. Required to send invoices and reminders via Outlook.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# The OAuth redirect URL registered in Azure, e.g.
# https://bkeeper.netlify.app/.netlify/functions/outlook-oauth-callback
MICROSOFT_REDIRECT_URI=

# ── Token encryption ──────────────────────────────────────────────────────
# 32-byte key as 64 hex chars. Used to encrypt/decrypt stored Outlook tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: changing this invalidates all stored Outlook tokens (reconnect needed).
TOKEN_ENCRYPTION_KEY=

# ── Receipt scanning (Anthropic) ──────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────
# Business timezone for reminder date math (default Australia/Sydney).
# BUSINESS_TIMEZONE=Australia/Sydney
# Netlify sets URL automatically in production; only needed for local override.
# URL=https://bkeeper.netlify.app
